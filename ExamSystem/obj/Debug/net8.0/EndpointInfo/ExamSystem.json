  "components": {
    "schemas": {
      "AssignRoleDto": {
        "required": [
          "role"
        ],
        "type": "object",
        "properties": {
          "role": {
            "minLength": 1,
            "pattern": "Admin|Teacher|Student",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CreateAnswerDto": {
        "required": [
          "answerText",
          "questionId",
          "resultId"
        ],
        "type": "object",
        "properties": {
          "resultId": {
            "type": "integer",
            "format": "int32"
          },
          "questionId": {
            "type": "integer",
            "format": "int32"
          },
          "answerText": {
            "minLength": 1,
            "type": "string"
          },
          "isCorrect": {
            "type": "boolean"
          },
          "earnedPoint": {
            "maximum": 100,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "CreateExamDto": {
        "required": [
          "startTime",
          "status",
          "title"
        ],
        "type": "object",
        "properties": {
          "title": {
            "minLength": 3,
            "type": "string"
          },
          "duration": {
            "maximum": 300,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "minLength": 1,
            "pattern": "active|inactive|finished",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CreateQuestionDto": {
        "required": [
          "correctAnswer",
          "examId",
          "text",
          "type"
        ],
        "type": "object",
        "properties": {
          "examId": {
            "type": "integer",
            "format": "int32"
          },
          "text": {
            "minLength": 5,
            "type": "string"
          },
          "type": {
            "minLength": 1,
            "pattern": "multiple_choice|true_false|open",
            "type": "string"
          },
          "options": {
            "type": "string",
            "nullable": true
          },
          "correctAnswer": {
            "minLength": 1,
            "type": "string"
          },
          "point": {
            "maximum": 100,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "CreateResultDto": {
        "required": [
          "examId",
          "studentId"
        ],
        "type": "object",
        "properties": {
          "examId": {
            "type": "integer",
            "format": "int32"
          },
          "studentId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "LoginDto": {
        "required": [
          "password",
          "userName"
        ],
        "type": "object",
        "properties": {
          "userName": {
            "minLength": 4,
            "type": "string"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "RegisterDto": {
        "required": [
          "fullName",
          "password",
          "userName"
        ],
        "type": "object",
        "properties": {
          "fullName": {
            "minLength": 8,
            "type": "string"
          },
          "userName": {
            "minLength": 4,
            "type": "string"
          },
          "password": {
            "minLength": 8,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ResetPasswordDto": {
        "required": [
          "newPassword"
        ],
        "type": "object",
        "properties": {
          "newPassword": {
            "minLength": 8,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "SubmitExamDto": {
        "required": [
          "answers",
          "resultId"
        ],
        "type": "object",
        "properties": {
          "resultId": {
            "type": "integer",
            "format": "int32"
          },
          "answers": {
            "minItems": 1,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateAnswerDto"
            }
          }
        },
        "additionalProperties": false
      },
      "UpdateExamDto": {
        "required": [
          "startTime",
          "status",
          "title"
        ],
        "type": "object",
        "properties": {
          "title": {
            "minLength": 3,
            "type": "string"
          },
          "duration": {
            "maximum": 300,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "minLength": 1,
            "pattern": "active|inactive|finished",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "UpdateQuestionDto": {
        "required": [
          "correctAnswer",
          "text",
          "type"
        ],
        "type": "object",
        "properties": {
          "text": {
            "minLength": 5,
            "type": "string"
          },
          "type": {
            "minLength": 1,
            "pattern": "multiple_choice|true_false|open",
            "type": "string"
          },
          "options": {
            "type": "string",
            "nullable": true
          },
          "correctAnswer": {
            "minLength": 1,
            "type": "string"
          },
          "point": {
            "maximum": 100,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "UpdateResultDto": {
        "required": [
          "status"
        ],
        "type": "object",
        "properties": {
          "status": {
            "minLength": 1,
            "pattern": "pending|graded",
            "type": "string"
          },
          "score": {
            "maximum": 2147483647,
            "minimum": 0,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "Token daxil edin",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "Bearer": [ ]
    }
  ]
}