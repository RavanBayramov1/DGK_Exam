  "components": {
    "schemas": {
      "AssignRoleDto": {
        "type": "object",
        "properties": {
          "role": {
            "$ref": "#/components/schemas/UserRole"
          },
          "groupId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateExamDto": {
        "required": [
          "groupId",
          "startTime",
          "subjectId",
          "title"
        ],
        "type": "object",
        "properties": {
          "title": {
            "minLength": 3,
            "type": "string"
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "durationMinutes": {
            "maximum": 180,
            "minimum": 5,
            "type": "integer",
            "format": "int32"
          },
          "shuffleQuestions": {
            "type": "boolean"
          },
          "shuffleOptions": {
            "type": "boolean"
          },
          "showResultsToStudent": {
            "type": "boolean"
          },
          "groupId": {
            "type": "integer",
            "format": "int32"
          },
          "subjectId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "CreateGroupDto": {
        "required": [
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "minLength": 2,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CreateQuestionDto": {
        "required": [
          "questionText",
          "subjectId",
          "type"
        ],
        "type": "object",
        "properties": {
          "questionText": {
            "minLength": 5,
            "type": "string"
          },
          "type": {
            "$ref": "#/components/schemas/QuestionType"
          },
          "defaultPoints": {
            "maximum": 100,
            "minimum": 0,1,
            "type": "number",
            "format": "double"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "correctAnswers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "subjectId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "CreateSubjectDto": {
        "required": [
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "minLength": 2,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "Error": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "nullable": true
          },
          "type": {
            "$ref": "#/components/schemas/ErrorType"
          },
          "description": {
            "type": "string",
            "nullable": true
